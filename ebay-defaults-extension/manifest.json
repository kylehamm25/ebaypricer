{
  "manifest_version": 3,
  "name": "eBay Listing Defaults",
  "version": "1.0",
  "description": "Automatically fills preferred eBay listing defaults.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.ebay.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/*"
      ],
      "js": [
        "defaults.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
